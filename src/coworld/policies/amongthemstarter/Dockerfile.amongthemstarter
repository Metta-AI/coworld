# Generated starter Dockerfile for the Among Them starter policy.
#
# This keeps the editable starter small while building against the same
# BitWorld source revision that the copied starter policy came from.
FROM alpine AS build

ARG BITWORLD_REPO=https://github.com/Metta-AI/bitworld.git
ARG BITWORLD_REF=master

RUN apk add --no-cache build-base curl gcompat git

RUN if [ "$(apk --print-arch)" = "x86_64" ]; then \
    curl -fsSL \
      -o /usr/local/bin/nimby \
https://github.com/treeform/nimby/releases/download/0.1.26/nimby-Linux-X64; \
  elif [ "$(apk --print-arch)" = "aarch64" ]; then \
    curl -fsSL \
      -o /usr/local/bin/nimby \
https://github.com/treeform/nimby/releases/download/0.1.26/nimby-Linux-ARM64; \
  else \
    echo "unsupported arch: $(apk --print-arch)" && exit 1; \
  fi && \
  chmod +x /usr/local/bin/nimby && \
  nimby use 2.2.4

ENV PATH="/root/.nimby/nim/bin:$PATH"

WORKDIR /workspace
RUN git clone "$BITWORLD_REPO" bitworld
WORKDIR /workspace/bitworld
RUN git checkout "$BITWORLD_REF"

RUN nimby --global sync nimby.lock && \
  cat nim.cfg >> /root/.nimby/nim/config/nim.cfg

COPY amongthemstarter.nim among_them/players/amongthemstarter/amongthemstarter.nim
WORKDIR /workspace/bitworld/among_them/players/amongthemstarter
RUN nim c \
  -d:release \
  -d:botHeadless \
  --nimcache:/tmp/bitworld-nimcache \
  --out:amongthemstarter \
  amongthemstarter.nim

FROM alpine

WORKDIR /workspace/bitworld
COPY --from=build \
  /workspace/bitworld/among_them/players/amongthemstarter/amongthemstarter \
  /bin/amongthemstarter
COPY --from=build /workspace/bitworld/among_them/*.json ./among_them/
COPY --from=build /workspace/bitworld/among_them/*.aseprite ./among_them/
COPY --from=build /workspace/bitworld/among_them/*.png ./among_them/
COPY --from=build /workspace/bitworld/client/data ./client/data

WORKDIR /workspace/bitworld/among_them/players
CMD ["/bin/amongthemstarter", "--address:host.docker.internal", "--port:8080"]
