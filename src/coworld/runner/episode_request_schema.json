{
  "$defs": {
    "CoworldCertificationFixture": {
      "additionalProperties": false,
      "properties": {
        "game_config": {
          "additionalProperties": true,
          "title": "Game Config",
          "type": "object"
        },
        "players": {
          "items": {
            "$ref": "#/$defs/CoworldCertificationPlayer"
          },
          "minItems": 1,
          "title": "Players",
          "type": "array"
        }
      },
      "required": ["game_config", "players"],
      "title": "CoworldCertificationFixture",
      "type": "object"
    },
    "CoworldCertificationPlayer": {
      "additionalProperties": false,
      "properties": {
        "player_id": {
          "minLength": 1,
          "title": "Player Id",
          "type": "string"
        }
      },
      "required": ["player_id"],
      "title": "CoworldCertificationPlayer",
      "type": "object"
    },
    "CoworldDocPage": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "if": {
            "pattern": "^play_"
          },
          "minLength": 1,
          "then": {
            "pattern": "^play_[a-z0-9][a-z0-9_-]*\\.md$"
          },
          "title": "Id",
          "type": "string"
        },
        "title": {
          "minLength": 1,
          "title": "Title",
          "type": "string"
        },
        "content": {
          "discriminator": {
            "mapping": {
              "text": "#/$defs/CoworldTextDoc",
              "uri": "#/$defs/CoworldUriDoc"
            },
            "propertyName": "type"
          },
          "oneOf": [
            {
              "$ref": "#/$defs/CoworldTextDoc"
            },
            {
              "$ref": "#/$defs/CoworldUriDoc"
            }
          ],
          "title": "Content"
        }
      },
      "required": ["id", "title", "content"],
      "title": "CoworldDocPage",
      "type": "object"
    },
    "CoworldDocs": {
      "additionalProperties": false,
      "properties": {
        "readme": {
          "anyOf": [
            {
              "discriminator": {
                "mapping": {
                  "text": "#/$defs/CoworldTextDoc",
                  "uri": "#/$defs/CoworldUriDoc"
                },
                "propertyName": "type"
              },
              "oneOf": [
                {
                  "$ref": "#/$defs/CoworldTextDoc"
                },
                {
                  "$ref": "#/$defs/CoworldUriDoc"
                }
              ]
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Readme"
        },
        "pages": {
          "allOf": [
            {
              "contains": {
                "properties": {
                  "id": {
                    "const": "rules.md"
                  }
                },
                "required": ["id"],
                "type": "object"
              },
              "maxContains": 1,
              "minContains": 1
            },
            {
              "contains": {
                "properties": {
                  "id": {
                    "pattern": "^play_[a-z0-9][a-z0-9_-]*\\.md$"
                  }
                },
                "required": ["id"],
                "type": "object"
              },
              "maxContains": 1,
              "minContains": 1
            }
          ],
          "items": {
            "$ref": "#/$defs/CoworldDocPage"
          },
          "title": "Pages",
          "type": "array"
        }
      },
      "required": ["pages"],
      "title": "CoworldDocs",
      "type": "object"
    },
    "CoworldGameManifest": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "version": {
          "minLength": 1,
          "title": "Version",
          "type": "string"
        },
        "description": {
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "owner": {
          "minLength": 1,
          "title": "Owner",
          "type": "string"
        },
        "config_schema": {
          "additionalProperties": true,
          "title": "Config Schema",
          "type": "object"
        },
        "results_schema": {
          "additionalProperties": true,
          "title": "Results Schema",
          "type": "object"
        },
        "runnable": {
          "$ref": "#/$defs/CoworldRunnableSpec",
          "properties": {
            "type": {
              "const": "game"
            }
          }
        },
        "protocols": {
          "$ref": "#/$defs/CoworldProtocolDocs"
        },
        "docs": {
          "$ref": "#/$defs/CoworldDocs"
        }
      },
      "required": [
        "name",
        "version",
        "description",
        "owner",
        "config_schema",
        "results_schema",
        "runnable",
        "protocols",
        "docs"
      ],
      "title": "CoworldGameManifest",
      "type": "object"
    },
    "CoworldManifest": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Schema for a complete game world in the Softmax universe.",
      "properties": {
        "$schema": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "$Schema"
        },
        "game": {
          "$ref": "#/$defs/CoworldGameManifest",
          "description": "Game runnable and protocol metadata. Role docs: docs/roles/game.md."
        },
        "player": {
          "description": "Bundled player runnables. Role docs: docs/roles/player.md.",
          "items": {
            "$ref": "#/$defs/CoworldManifestRoleSpec"
          },
          "minItems": 1,
          "title": "Player",
          "type": "array"
        },
        "reporter": {
          "description": "Reporter runnables. Must declare at least one entry; Coworlds without a custom reporter may reference `ghcr.io/metta-ai/reporters-default:latest`. Role docs: docs/roles/reporter.md.",
          "items": {
            "$ref": "#/$defs/CoworldManifestRoleSpec"
          },
          "minItems": 1,
          "title": "Reporter",
          "type": "array"
        },
        "commissioner": {
          "description": "Optional commissioner runnables. Role docs: docs/roles/commissioner.md.",
          "items": {
            "$ref": "#/$defs/CoworldManifestRoleSpec"
          },
          "title": "Commissioner",
          "type": "array"
        },
        "grader": {
          "description": "Grader runnables. Must declare at least one entry; Coworlds without a custom grader may reference `ghcr.io/metta-ai/graders-default:latest`. Role docs: docs/roles/grader.md.",
          "items": {
            "$ref": "#/$defs/CoworldManifestRoleSpec"
          },
          "minItems": 1,
          "title": "Grader",
          "type": "array"
        },
        "diagnoser": {
          "description": "Optional diagnoser runnables. Role docs: docs/roles/diagnoser.md.",
          "items": {
            "$ref": "#/$defs/CoworldManifestRoleSpec"
          },
          "title": "Diagnoser",
          "type": "array"
        },
        "optimizer": {
          "description": "Optional optimizer runnables. Role docs: docs/roles/optimizer.md.",
          "items": {
            "$ref": "#/$defs/CoworldManifestRoleSpec"
          },
          "title": "Optimizer",
          "type": "array"
        },
        "variants": {
          "items": {
            "$ref": "#/$defs/CoworldVariant"
          },
          "minItems": 1,
          "title": "Variants",
          "type": "array"
        },
        "certification": {
          "$ref": "#/$defs/CoworldCertificationFixture"
        }
      },
      "required": ["game", "player", "reporter", "grader", "variants", "certification"],
      "title": "Coworld Manifest",
      "type": "object"
    },
    "CoworldManifestRoleSpec": {
      "additionalProperties": false,
      "properties": {
        "type": {
          "enum": ["player", "reporter", "commissioner", "grader", "diagnoser", "optimizer"],
          "title": "Type",
          "type": "string"
        },
        "image": {
          "title": "Image",
          "type": "string"
        },
        "run": {
          "items": {
            "type": "string"
          },
          "title": "Run",
          "type": "array"
        },
        "env": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Env",
          "type": "object"
        },
        "source_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Url"
        },
        "id": {
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "description": {
          "minLength": 1,
          "title": "Description",
          "type": "string"
        }
      },
      "required": ["type", "image", "id", "name", "description"],
      "title": "CoworldManifestRoleSpec",
      "type": "object"
    },
    "CoworldProtocolDocs": {
      "additionalProperties": false,
      "properties": {
        "player": {
          "discriminator": {
            "mapping": {
              "text": "#/$defs/CoworldTextDoc",
              "uri": "#/$defs/CoworldUriDoc"
            },
            "propertyName": "type"
          },
          "oneOf": [
            {
              "$ref": "#/$defs/CoworldTextDoc"
            },
            {
              "$ref": "#/$defs/CoworldUriDoc"
            }
          ],
          "title": "Player"
        },
        "global": {
          "discriminator": {
            "mapping": {
              "text": "#/$defs/CoworldTextDoc",
              "uri": "#/$defs/CoworldUriDoc"
            },
            "propertyName": "type"
          },
          "oneOf": [
            {
              "$ref": "#/$defs/CoworldTextDoc"
            },
            {
              "$ref": "#/$defs/CoworldUriDoc"
            }
          ],
          "title": "Global"
        }
      },
      "required": ["player", "global"],
      "title": "CoworldProtocolDocs",
      "type": "object"
    },
    "CoworldRunnableSpec": {
      "additionalProperties": false,
      "properties": {
        "type": {
          "enum": ["game", "player", "reporter", "commissioner", "grader", "diagnoser", "optimizer"],
          "title": "Type",
          "type": "string"
        },
        "image": {
          "title": "Image",
          "type": "string"
        },
        "run": {
          "items": {
            "type": "string"
          },
          "title": "Run",
          "type": "array"
        },
        "env": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Env",
          "type": "object"
        },
        "source_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Url"
        }
      },
      "required": ["type", "image"],
      "title": "CoworldRunnableSpec",
      "type": "object"
    },
    "CoworldTextDoc": {
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "text",
          "title": "Type",
          "type": "string"
        },
        "value": {
          "minLength": 1,
          "title": "Value",
          "type": "string"
        }
      },
      "required": ["type", "value"],
      "title": "CoworldTextDoc",
      "type": "object"
    },
    "CoworldUriDoc": {
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "uri",
          "title": "Type",
          "type": "string"
        },
        "value": {
          "minLength": 1,
          "pattern": "^https?://",
          "title": "Value",
          "type": "string"
        }
      },
      "required": ["type", "value"],
      "title": "CoworldUriDoc",
      "type": "object"
    },
    "CoworldVariant": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "game_config": {
          "additionalProperties": true,
          "title": "Game Config",
          "type": "object"
        },
        "description": {
          "minLength": 1,
          "title": "Description",
          "type": "string"
        }
      },
      "required": ["id", "name", "game_config", "description"],
      "title": "CoworldVariant",
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Runner-facing request for one Coworld episode.",
  "properties": {
    "$schema": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "$Schema"
    },
    "manifest": {
      "$ref": "#/$defs/CoworldManifest"
    },
    "game_config": {
      "additionalProperties": true,
      "title": "Game Config",
      "type": "object"
    },
    "players": {
      "items": {
        "$ref": "#/$defs/CoworldRunnableSpec",
        "properties": {
          "type": {
            "const": "player"
          }
        }
      },
      "title": "Players",
      "type": "array"
    },
    "episode_tags": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Episode Tags",
      "type": "object"
    },
    "policy_names": {
      "anyOf": [
        {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Optional runner metadata with one display name per player slot. These names stay outside game_config; runners expose them through runner-owned channels.",
      "title": "Policy Names"
    }
  },
  "required": ["manifest", "game_config", "players"],
  "title": "Coworld Episode Job Spec",
  "type": "object"
}
