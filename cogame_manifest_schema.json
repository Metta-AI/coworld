{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CoGame Manifest",
  "description": "Manifest for a cogame.",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "version", "description", "owner", "config_schema", "results_schema", "image_uri", "protocols"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "description": "Contact email for the game owner.",
      "type": "string",
      "format": "email",
      "minLength": 1
    },
    "config_schema": {
      "description": "JSON Schema for the game config. Must require tokens.",
      "type": "object"
    },
    "results_schema": {
      "description": "JSON Schema for the game results. Must require scores.",
      "type": "object"
    },
    "image_uri": {
      "type": "string",
      "minLength": 1
    },
    "protocols": {
      "$ref": "#/$defs/GameProtocolDocs"
    }
  },
  "$defs": {
    "GameProtocolDocs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["player", "global"],
      "properties": {
        "player": {
          "description": "Documentation about the engine-player protocol served over /player?slot=0&token=..., including reconnect behavior.",
          "type": "string",
          "minLength": 1
        },
        "global": {
          "description": "Documentation about the global protocol served over /global, including mid-episode viewer joins.",
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
