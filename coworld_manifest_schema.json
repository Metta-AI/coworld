{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Coworld Manifest",
  "description": "Schema for a complete game world in the Softmax universe.",
  "type": "object",
  "additionalProperties": false,
  "required": ["game", "player", "variants", "certification"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "game": {
      "description": "The Cogame for this world.",
      "$ref": "#/$defs/CogameManifest"
    },
    "player": {
      "description": "Base player policies that users can fork from and that can competently play the game.",
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/PlayerRunnable"
      }
    },
    "grader": {
      "description": "Base grader policies that estimate expected probability of winning, or score for games without win/loss outcomes.",
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "#/$defs/GraderRunnable"
      }
    },
    "reporter": {
      "description": "Base reporter policies that summarize logs from game experience into high-level descriptions of important events.",
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "#/$defs/ReporterRunnable"
      }
    },
    "commissioner": {
      "description": "Base commissioner policies that run tournaments and produce rankings.",
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "#/$defs/CommissionerRunnable"
      }
    },
    "diagnoser": {
      "description": "Base diagnoser policies that assess basic competence across important mechanics and gameplay situations.",
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "#/$defs/DiagnoserRunnable"
      }
    },
    "optimizer": {
      "description": "Base optimizer policies or agents that improve players and graders.",
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "#/$defs/OptimizerRunnable"
      }
    },
    "variants": {
      "description": "Targeted game configs that factorize the game into mechanics for training and evaluation.",
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/Variant"
      }
    },
    "certification": {
      "description": "Coworld-level smoke episode used by the platform certifier. References declared variant and player IDs; the certifier supplies artifact destinations.",
      "$ref": "#/$defs/CertificationFixture"
    }
  },
  "$defs": {
    "CogameManifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "description",
        "owner",
        "config_schema",
        "results_schema",
        "runnable",
        "protocols"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "description": "Contact email for the game owner.",
          "type": "string",
          "format": "email",
          "minLength": 1
        },
        "config_schema": {
          "description": "JSON Schema for the game config. Must require tokens. The tokens array may allow zero items for games that support free play without runner-managed policy slots.",
          "type": "object"
        },
        "results_schema": {
          "description": "JSON Schema for the game results. Must require scores.",
          "type": "object"
        },
        "runnable": {
          "description": "Runnable definition for the Cogame engine container.",
          "$ref": "#/$defs/GameRunnable"
        },
        "protocols": {
          "$ref": "#/$defs/GameProtocolDocs"
        }
      }
    },
    "GameProtocolDocs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["player", "global"],
      "properties": {
        "player": {
          "description": "Documentation about the engine-player protocol served over /player?slot=0&token=..., including reconnect behavior.",
          "type": "string",
          "minLength": 1
        },
        "global": {
          "description": "Documentation about the global protocol served over /global, including mid-episode viewer joins.",
          "type": "string",
          "minLength": 1
        }
      }
    },
    "Runnable": {
      "type": "object",
      "required": ["type", "image"],
      "properties": {
        "type": {
          "enum": ["game", "player", "grader", "reporter", "commissioner", "diagnoser", "optimizer"]
        },
        "image": {
          "type": "string",
          "minLength": 1
        },
        "run": {
          "description": "Complete argv to execute. Omit to use the image ENTRYPOINT/CMD.",
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "env": {
          "description": "Public, reproducible environment variables for the runnable.",
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "DeclaredRunnable": {
      "allOf": [
        {
          "$ref": "#/$defs/Runnable"
        },
        {
          "type": "object",
          "required": ["id", "name", "description"],
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "name": {
              "type": "string",
              "minLength": 1
            },
            "description": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "GameRunnable": {
      "allOf": [
        {
          "$ref": "#/$defs/Runnable"
        },
        {
          "properties": {
            "type": {
              "const": "game"
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "PlayerRunnable": {
      "allOf": [
        {
          "$ref": "#/$defs/DeclaredRunnable"
        },
        {
          "properties": {
            "type": {
              "const": "player"
            }
          }
        }
      ]
    },
    "GraderRunnable": {
      "allOf": [
        {
          "$ref": "#/$defs/DeclaredRunnable"
        },
        {
          "properties": {
            "type": {
              "const": "grader"
            }
          }
        }
      ]
    },
    "ReporterRunnable": {
      "allOf": [
        {
          "$ref": "#/$defs/DeclaredRunnable"
        },
        {
          "properties": {
            "type": {
              "const": "reporter"
            }
          }
        }
      ]
    },
    "CommissionerRunnable": {
      "allOf": [
        {
          "$ref": "#/$defs/DeclaredRunnable"
        },
        {
          "properties": {
            "type": {
              "const": "commissioner"
            }
          }
        }
      ]
    },
    "DiagnoserRunnable": {
      "allOf": [
        {
          "$ref": "#/$defs/DeclaredRunnable"
        },
        {
          "properties": {
            "type": {
              "const": "diagnoser"
            }
          }
        }
      ]
    },
    "OptimizerRunnable": {
      "allOf": [
        {
          "$ref": "#/$defs/DeclaredRunnable"
        },
        {
          "properties": {
            "type": {
              "const": "optimizer"
            }
          }
        }
      ]
    },
    "Variant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "game_config", "description"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "game_config": {
          "type": "object"
        },
        "parent_id": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "CertificationFixture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["variant_id", "players"],
      "properties": {
        "variant_id": {
          "description": "ID of the declared variant used for the smoke episode.",
          "type": "string",
          "minLength": 1
        },
        "players": {
          "description": "Player slots for the smoke episode, each referencing a declared player by ID.",
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/CertificationPlayer"
          }
        }
      }
    },
    "CertificationPlayer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["player_id"],
      "properties": {
        "player_id": {
          "type": "string",
          "minLength": 1
        },
        "initial_params": {
          "description": "Optional query params appended to the player's websocket URL.",
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "integer", "boolean"]
          }
        }
      }
    }
  }
}
